<div class="cv-page">
  <header class="cv-header">
    <h1 class="cv-header__name">{{ profile.name }}</h1>
    {% if profile.title != "" %}<p class="cv-header__title">{{ profile.title }}</p>{% endif %}
    <div class="cv-header__contact">
      {% if profile.email != "" %}<span class="cv-header__contact-item">{{ profile.email }}</span>{% endif %}
      {% if profile.phone != "" %}<span class="cv-header__contact-item">{{ profile.phone }}</span>{% endif %}
      {% if profile.location != "" %}<span class="cv-header__contact-item">{{ profile.location }}</span>{% endif %}
      {% if profile.website != "" %}<span class="cv-header__contact-item"><a href="{{ profile.website }}">{{ profile.website | strip_protocol }}</a></span>{% endif %}
      {% for link in profile.socialLinks %}<span class="cv-header__contact-item"><a href="{{ link.url }}">{{ link.label }}</a></span>{% endfor %}
    </div>
  </header>
  <div class="cv-body">
    {% for section in slots.main %}
      <section class="cv-section cv-section--{{ section.type }}">
        <h2 class="cv-section__title">{{ section.title }}</h2>
        {% render section.type, section: section %}
      </section>
    {% endfor %}
  </div>
</div>
