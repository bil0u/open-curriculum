{% for item in section.items %}
<div class="cv-item">
  <div class="cv-item__header">
    <span class="cv-item__degree">{{ item.degree }}{% if item.field != "" %} — {{ item.field }}{% endif %}</span>
    <span class="cv-item__dates">{{ item.startDate | format_date: "yyyy" }} – {{ item.endDate | format_date: "yyyy", "Present" }}</span>
  </div>
  <div class="cv-item__org">{{ item.institution }}{% if item.grade != "" %} · {{ item.grade }}{% endif %}</div>
  {% if item.description != "" %}<p class="cv-item__description">{{ item.description }}</p>{% endif %}
</div>
{% endfor %}
