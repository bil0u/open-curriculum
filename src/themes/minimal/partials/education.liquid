{% for item in section.items %}
<div class="cv-item cv-item--timeline">
  <div class="cv-item__date">{{ item.startDate | format_date: "yyyy" }} – {{ item.endDate | format_date: "yyyy", "Present" }}</div>
  <div class="cv-item__content">
    <div class="cv-item__degree">{{ item.degree }}{% if item.field != "" %} — {{ item.field }}{% endif %}</div>
    <div class="cv-item__org">{{ item.institution }}{% if item.grade != "" %} · {{ item.grade }}{% endif %}</div>
    {% if item.description != "" %}<p class="cv-item__description">{{ item.description }}</p>{% endif %}
  </div>
</div>
{% endfor %}
